{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-stat",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "opener:allow-reveal-item-in-dir",
    "opener:allow-open-path"
  ]
}
